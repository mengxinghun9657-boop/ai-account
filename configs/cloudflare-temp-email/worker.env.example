# Example values for a cloudflare_temp_email deployment
# Replace all placeholder values before use.

CLOUDFLARE_API_TOKEN=replace-with-cloudflare-api-token
CLOUDFLARE_ACCOUNT_ID=replace-with-cloudflare-account-id
WORKER_NAME=cloudflare-temp-email
WORKER_DOMAIN=example.workers.dev
MAIL_DOMAIN=example.com
ADMIN_PASSWORD=replace-with-worker-admin-password

# Notes:
# 1. Domain example.com must already be active in Cloudflare.
# 2. Email Routing must be enabled.
# 3. Catch-All must be configured to Send to a Worker.
