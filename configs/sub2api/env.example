# Environment example for Sub2Api deployment

PUBLIC_IP=your.server.ip
SUB2API_PORT=8080
SUB2API_ADMIN_EMAIL=admin@example.com
TZ_NAME=Asia/Shanghai
MIHOMO_HTTP_PROXY=http://127.0.0.1:7890
ROOT_DIR=/opt/sub2api
PODMAN_NETWORK=sub2api-net

# Generated at deploy time:
# - ADMIN_PASSWORD
# - JWT_SECRET
# - TOTP_ENCRYPTION_KEY
# - POSTGRES_PASSWORD
# - REDIS_PASSWORD
